# Apify — get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Anthropic — get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# TikTok — get credentials at https://developers.tiktok.com (My Apps → your app)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ElevenLabs — get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Google AI Studio (Gemini / Nano Banana Pro) — get key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_key_here

# Muapi — video generation (275+ AI models) — get key at https://muapi.ai
MUAPI_API_KEY=your_muapi_key_here

# HeyGen — AI avatar video generation — get key at https://app.heygen.com/settings
HEYGEN_API_KEY=your_heygen_key_here

# Kalodata — product intelligence — sign up at https://kalodata.com
KALODATA_EMAIL=your_kalodata_email
KALODATA_PASSWORD=your_kalodata_password
